# ============================================================
# بوست سوشال — Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم
# cp .env.example .env
# ============================================================

# ── App ───────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
DATABASE_URL=sqlite:///social_post.db
FLASK_ENV=production
PORT=5000
LOG_LEVEL=info

# ── Admin ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ── AI Providers ──────────────────────────────────────────────
# Cohere (مجاني) — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Google Gemini (مجاني) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Cloudinary (رفع الصور) ────────────────────────────────────
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Image Generation ──────────────────────────────────────────
# Cloudflare Worker URL (Flux 2)
WORKER_URL=

# Pollinations (fallback — مجاني)
POLLINATIONS_KEY=

# ── Facebook & Instagram ──────────────────────────────────────
# https://developers.facebook.com/tools/explorer/
FB_PAGE_ID=
FB_ACCESS_TOKEN=
IG_USER_ID=
IG_ACCESS_TOKEN=

# ── Twitter / X ───────────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── Threads ───────────────────────────────────────────────────
# https://developers.facebook.com/docs/threads
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── LinkedIn ──────────────────────────────────────────────────
# https://www.linkedin.com/developers/apps
LI_PERSON_ID=
LI_ACCESS_TOKEN=

# ── Telegram Bot ──────────────────────────────────────────────
# 1. افتح @BotFather → /newbot → انسخ الـ Token
# 2. افتح @userinfobot → انسخ الـ ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Scheduler ─────────────────────────────────────────────────
IDEA_FACTORY_TIME=08:00
POST_TIMES=09:00,13:00,17:00,21:00
