# ============================================================
# بوست سوشال — Environment Variables
# cp .env.example .env  ثم عدّل القيم
# ============================================================

# ── App (إلزامي) ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
DATABASE_URL=sqlite:///social_post.db
FLASK_ENV=production
PORT=5000
LOG_LEVEL=info

# Upstash Redis — لحفظ الإعدادات بشكل دائم (لا تضيع عند restart)
# https://console.upstash.com → Create Database → REST URL
REDIS_URL=

# Google Sheets Backup
# Sheet ID من رابط الـ Sheet
GOOGLE_SHEET_ID=1LmIWYVqeQejjBVjlIZICCuuaGTU8h25zKFSnwNw65Vs
# محتوى ملف JSON للـ Service Account (كاملاً في سطر واحد)
GOOGLE_SHEETS_CREDENTIALS=/home/nopoh55678/social-post/credentials.json

# PythonAnywhere (للـ auto-reload بعد التحديث)
PYTHONANYWHERE_TOKEN=
PYTHONANYWHERE_USERNAME=

# ── Admin (إلزامي) ────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ══════════════════════════════════════════════════════════════
# AI PROVIDERS — وكلاء الذكاء الاصطناعي
# ══════════════════════════════════════════════════════════════

# Cohere (مجاني) — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Google Gemini (مجاني) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (مجاني سريع) — https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (مجاني جزئياً) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (مدفوع) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── عدة مفاتيح لكل provider (rotation تلقائي) ────────────────
# الصيغة: {PROVIDER}_KEY_{N} و {PROVIDER}_KEY_{N}_LABEL
COHERE_KEY_1=
COHERE_KEY_1_LABEL=حساب 1
COHERE_KEY_2=
COHERE_KEY_2_LABEL=حساب 2
COHERE_KEY_3=
COHERE_KEY_3_LABEL=حساب 3

GEMINI_KEY_1=
GEMINI_KEY_1_LABEL=حساب 1
GEMINI_KEY_2=
GEMINI_KEY_2_LABEL=حساب 2

GROQ_KEY_1=
GROQ_KEY_1_LABEL=حساب 1
GROQ_KEY_2=
GROQ_KEY_2_LABEL=حساب 2

OPENROUTER_KEY_1=
OPENROUTER_KEY_1_LABEL=حساب 1

# ══════════════════════════════════════════════════════════════
# IMAGE SERVICES — خدمات الصور
# ══════════════════════════════════════════════════════════════

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare Worker (Flux 2 image generation)
WORKER_URL=

# Pollinations (fallback مجاني) — https://pollinations.ai
POLLINATIONS_KEY=

# Frame overlay image URL (Cloudinary URL للإطار)
FRAME_URL=

# ApyHub — https://apyhub.com/profile/api
APYHUB_TOKEN=

# ── Image settings ────────────────────────────────────────────
IMAGE_RATIO_PERCENT=90
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1350
IMAGE_MODEL=flux
FRAME_OPACITY=100

# ══════════════════════════════════════════════════════════════
# SOCIAL PLATFORMS — منصات السوشال ميديا
# ══════════════════════════════════════════════════════════════

# Facebook & Instagram — https://developers.facebook.com/tools/explorer/
FB_PAGE_ID=
FB_ACCESS_TOKEN=
IG_USER_ID=
IG_ACCESS_TOKEN=

# Twitter / X — https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Threads — https://developers.facebook.com/docs/threads
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# LinkedIn — https://www.linkedin.com/developers/apps
LI_PERSON_ID=
LI_ACCESS_TOKEN=

# ══════════════════════════════════════════════════════════════
# TELEGRAM BOT — بوت التحكم
# ══════════════════════════════════════════════════════════════
# 1. افتح @BotFather → /newbot → انسخ الـ Token
# 2. افتح @userinfobot → انسخ الـ Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ══════════════════════════════════════════════════════════════
# SCHEDULER — مواعيد النشر
# ══════════════════════════════════════════════════════════════
IDEA_FACTORY_TIME=08:00
SCHED_1=09:00
SCHED_2=13:00
SCHED_3=17:00
SCHED_4=21:00
DELAY_MIN_SECONDS=60
DELAY_MAX_SECONDS=420
