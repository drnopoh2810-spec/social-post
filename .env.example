# ============================================================
# بوست سوشال — Environment Variables
# cp .env.example .env  ثم عدّل القيم
# ============================================================

# ══════════════════════════════════════════════════════════════
# APP — إلزامي
# ══════════════════════════════════════════════════════════════
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
DATABASE_URL=sqlite:///social_post.db
FLASK_ENV=production
PORT=5000

# ── Admin ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ══════════════════════════════════════════════════════════════
# REDIS — Upstash (لحفظ الإعدادات بشكل دائم)
# https://console.upstash.com → Create Database
# انسخ "Redis URL" من صفحة الـ database
# ══════════════════════════════════════════════════════════════
REDIS_URL=rediss://default:TOKEN@host.upstash.io:6379

# ══════════════════════════════════════════════════════════════
# AI PROVIDERS — وكلاء الذكاء الاصطناعي
# ══════════════════════════════════════════════════════════════

# Google Gemini (مجاني ⭐ — الأفضل) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (مجاني سريع جداً) — https://console.groq.com/keys
GROQ_API_KEY=

# Cohere (مجاني) — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# OpenRouter (مجاني جزئياً) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# api.airforce (مجاني) — https://api.airforce/dashboard
# AIRFORCE_API_KEY=

# OpenAI (مدفوع) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── عدة مفاتيح لكل provider (rotation + failover تلقائي) ─────
# الصيغة: {PROVIDER}_KEY_{N}  و  {PROVIDER}_KEY_{N}_LABEL (اختياري)
GEMINI_KEY_1=
GEMINI_KEY_1_LABEL=حساب 1
GEMINI_KEY_2=
GEMINI_KEY_2_LABEL=حساب 2
GEMINI_KEY_3=
GEMINI_KEY_3_LABEL=حساب 3

GROQ_KEY_1=
GROQ_KEY_1_LABEL=حساب 1
GROQ_KEY_2=
GROQ_KEY_2_LABEL=حساب 2

COHERE_KEY_1=
COHERE_KEY_1_LABEL=حساب 1
COHERE_KEY_2=
COHERE_KEY_2_LABEL=حساب 2
COHERE_KEY_3=
COHERE_KEY_3_LABEL=حساب 3

OPENROUTER_KEY_1=
OPENROUTER_KEY_1_LABEL=حساب 1

# ══════════════════════════════════════════════════════════════
# IMAGE SERVICES — خدمات توليد الصور
# ══════════════════════════════════════════════════════════════

# Cloudinary (إلزامي لرفع الصور) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare Worker (Flux 2 — primary) — اختياري
WORKER_URL=

# Pollinations (last fallback — مجاني بدون مفتاح)
# سجّل على auth.pollinations.ai للحصول على token بدون watermark
POLLINATIONS_KEY=

# Frame overlay (PNG شفاف يُوضع فوق الصورة) — اختياري
FRAME_URL=
FRAME_OPACITY=100

# Image settings
IMAGE_RATIO_PERCENT=90
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1350
IMAGE_MODEL=flux

# ══════════════════════════════════════════════════════════════
# SOCIAL PLATFORMS — منصات السوشال ميديا
# ══════════════════════════════════════════════════════════════

# Facebook & Instagram — https://developers.facebook.com/tools/explorer/
FB_PAGE_ID=
FB_ACCESS_TOKEN=
IG_USER_ID=
IG_ACCESS_TOKEN=

# Twitter / X — https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Threads — https://developers.facebook.com/docs/threads
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# LinkedIn — https://www.linkedin.com/developers/apps
LI_PERSON_ID=
LI_ACCESS_TOKEN=

# ══════════════════════════════════════════════════════════════
# TELEGRAM BOT — بوت التحكم
# ══════════════════════════════════════════════════════════════
# 1. افتح @BotFather → /newbot → انسخ الـ Token
# 2. شغّل البوت → /myid → انسخ الـ Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ══════════════════════════════════════════════════════════════
# GOOGLE SHEETS — نسخ احتياطي للمنشورات
# ══════════════════════════════════════════════════════════════
# Sheet ID من رابط الـ Sheet
GOOGLE_SHEET_ID=
# مسار ملف credentials.json أو محتواه كاملاً
GOOGLE_SHEETS_CREDENTIALS=/home/USERNAME/social-post/credentials.json

# ══════════════════════════════════════════════════════════════
# PYTHONANYWHERE — للـ auto-reload بعد التحديث
# ══════════════════════════════════════════════════════════════
PYTHONANYWHERE_TOKEN=
PYTHONANYWHERE_USERNAME=

# ══════════════════════════════════════════════════════════════
# SCHEDULER — مواعيد النشر
# ══════════════════════════════════════════════════════════════
IDEA_FACTORY_TIME=08:00
SCHED_1=09:00
SCHED_2=13:00
SCHED_3=17:00
SCHED_4=21:00
DELAY_MIN_SECONDS=60
DELAY_MAX_SECONDS=420
